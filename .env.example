# Copy this file to .env and fill in real values.
# Free Postgres: create a project at https://neon.tech or https://supabase.com
# and paste its connection string below.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Free email sending for lead notifications: https://resend.com (free tier)
RESEND_API_KEY=""
LEAD_NOTIFICATION_EMAIL="you@example.com"
RESEND_FROM_EMAIL="Financial Sage <leads@yourdomain.com>"

# WhatsApp click-to-chat number, digits only with country code, e.g. 91XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER="91XXXXXXXXXX"

# Public site URL, used for canonical URLs, sitemap, and JSON-LD.
# Must match the domain Vercel actually serves without a redirect - check
# with `curl -I` before changing this. As of writing that's the www subdomain
# (the apex financialsage.co.in 308-redirects to it).
NEXT_PUBLIC_SITE_URL="https://www.financialsage.co.in"

# Analytics (optional, leave blank to disable)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""
